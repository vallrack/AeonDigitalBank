
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Permitir listar usuarios para verificar si un destinatario existe
    match /users {
      allow list: if isSignedIn();
    }

    match /users/{userId} {
      // Un usuario puede leer su propio perfil o cualquier perfil si es admin
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // Permitir creación de perfil propio
      allow create: if isSignedIn() && request.auth.uid == userId;
      
      // Permitir actualización de saldo propio o de otro usuario durante una transferencia
      // (En una app real esto se haría vía Cloud Functions por seguridad)
      allow update: if isSignedIn() && (
        request.auth.uid == userId || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance'])) ||
        isAdmin()
      );
      
      allow delete: if isAdmin();
      
      match /transactions/{transactionId} {
        // Permitir crear una transacción en la cuenta de otro usuario (para depósitos/transferencias)
        allow create: if isSignedIn();
        // Solo el dueño o admin puede leer/borrar
        allow read, update, delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
      
      match /virtualCards/{cardId} {
        allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      }
    }
  }
}
